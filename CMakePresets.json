{
  "version": 3,
  "configurePresets": [
    {
      "name": "mingw-release",
      "displayName": "MinGW Release (MSYS2)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "C:/msys64/mingw64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/msys64/mingw64/bin/g++.exe",
        "CMAKE_MAKE_PROGRAM": "C:/msys64/mingw64/bin/ninja.exe"
      }
    },
    {
      "name": "mingw-debug",
      "displayName": "MinGW Debug (MSYS2)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "C:/msys64/mingw64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/msys64/mingw64/bin/g++.exe",
        "CMAKE_MAKE_PROGRAM": "C:/msys64/mingw64/bin/ninja.exe"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "mingw-release",
      "jobs": 8
    },
    {
      "name": "debug",
      "configurePreset": "mingw-debug",
      "jobs": 8
    }
  ],
  "testPresets": [
    {
      "name": "release",
      "configurePreset": "mingw-release"
    }
  ]
}
